\begin_layout Standard
\begin_inset Formula 
\begin{equation}
f(\boldsymbol{x})\approx\sum_{j=1}^{n-1}\n{a_{j}\phi_{j}(\boldsymbol{x}).}
\end{equation}

\end_inset

Multiply from left with 
\begin_inset Formula $\int d^{D}x\,\phi_{i}(\boldsymbol{x})$
\end_inset

 to obtain
\begin_inset Formula 
\begin{equation}
\int d^{D}x\,\phi_{i}(\boldsymbol{x})f(\boldsymbol{x})\approx\int d^{D}x\,\sum_{j=1}^{n-1}\n{a_{j}\phi_{j}(\boldsymbol{x})=\sum_{j=1}^{n-1}a_{j}\underbrace{\int d^{D}x\phi_{i}(\boldsymbol{x})\phi_{j}(\boldsymbol{x})}_{M_{ij}}.}
\end{equation}

\end_inset

This can be written as linear system
\begin_inset Formula 
\begin{equation}
M\boldsymbol{a}=\boldsymbol{b}.
\end{equation}

\end_inset


