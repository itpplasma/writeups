\end{equation}

\end_inset


\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{equation}
C=\Phi^{T}\Phi=V\Lambda V^{T}
\end{equation}

\end_inset


\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{equation}
\Phi=\underbrace{U}_{n\times n}\underbrace{S}_{n\times N}\underbrace{V^{T}}_{N\times N}
\end{equation}

\end_inset


\begin_inset Formula 
\begin{equation}
S=\left(\begin{array}{ccc}
\sqrt{\lambda_{1}}\\
 & \sqrt{\lambda_{2}}
\end{array}\right)
\end{equation}

\end_inset


\begin_inset Formula 
\begin{equation}
\Phi\approx\underbrace{\tilde{U}}_{n\times p}\underbrace{\tilde{S}}_{p\times p}\underbrace{\tilde{V}^{T}}_{p\times N}
\end{equation}

\end_inset


\end_layout

