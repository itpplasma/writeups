\begin_layout Standard
\begin_inset Formula 
\begin{equation}
f(\boldsymbol{x})\approx\sum_{j=0}^{n-1}\n{a_{j}\phi_{j}(\boldsymbol{x})}
\end{equation}

\end_inset

Multiply from left with 
\begin_inset Formula $\sum_{k=1}^{N}\phi_{i}(\boldsymbol{x}^{(k)})$
\end_inset

 over 
\begin_inset Formula $N$
\end_inset

 trainings points to obtain
\begin_inset Formula 
\begin{equation}
\sum_{k=1}^{N}\phi_{i}(\boldsymbol{x}^{(k)})f(\boldsymbol{x}^{(k)})\approx\sum_{k=1}^{N}\phi_{i}(\boldsymbol{x}^{(k)})\sum_{j=0}^{n-1}\n{a_{j}\phi_{j}(\boldsymbol{x}^{(k)})=\sum_{j=0}^{n-1}a_{j}\underbrace{\sum_{k=1}^{N}\phi_{i}(\boldsymbol{x}^{(k)})\phi_{j}(\boldsymbol{x}^{(k)})}_{M_{ij}}.}
\end{equation}

\end_inset

This can be written as linear system
\begin_inset Formula 
\begin{equation}
M\boldsymbol{a}=\boldsymbol{b}.
\end{equation}

\end_inset


\end_layout

